# Lemon Squeeze configuration
# Copy to .env and fill in values you need. All keys are optional unless noted.

# --- Storage ---
LEMON_DB_PATH=./data/lemon.db

# --- LM Studio ---
# Default LM Studio server endpoint (OpenAI-compatible). Used by self_generated runner.
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# Path to LM Studio chat/log directory for ingestion (Windows default shown).
# Override per-machine.
LM_STUDIO_LOGS_DIR=C:\Users\User\.cache\lm-studio\conversations

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- LLM-assist classifier (optional) ---
# Provider used when the LLM-based classifier fallback runs. One of: lm_studio, openrouter, none.
CLASSIFIER_LLM_PROVIDER=none
CLASSIFIER_LLM_MODEL=meta-llama/llama-3.1-8b-instruct

# --- Tokenizer ---
# tiktoken encoding name used for rough token counts when a model-specific tokenizer isn't available.
DEFAULT_TOKEN_ENCODING=cl100k_base
